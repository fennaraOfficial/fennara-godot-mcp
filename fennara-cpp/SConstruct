#!/usr/bin/env python

import os
import glob
from SCons.Script import Exit

CacheDir(os.environ.get("SCONS_CACHE", ".scons_cache/"))

env = SConscript("godot-cpp/SConstruct")

if env["platform"] == "windows":
    env.Append(CPPPATH=["vendor/webview/include", "vendor/webview2/include"])
    env.Append(LIBS=["advapi32", "comdlg32", "ole32", "shell32", "shlwapi", "user32", "version"])
elif env["platform"] == "macos":
    env.Append(CXXFLAGS=["-fblocks"])
    env.Append(LINKFLAGS=["-framework", "Cocoa", "-framework", "WebKit"])
    env.Append(LIBS=["dl"])
elif env["platform"] == "linux":
    env.Append(CPPPATH=["vendor/cef"])
    env.Append(LIBS=["dl"])

# Auto-discover include directories
for root, dirs, files in os.walk("include"):
    env.Append(CPPPATH=[root])

# Keep build files inside this project
build_dir = "build"
env.VariantDir(build_dir, "src", duplicate=0)

# Discover sources
sources = glob.glob("src/**/*.cpp", recursive=True)
sources += glob.glob("src/**/*.c", recursive=True)
if env["platform"] == "macos":
    sources += glob.glob("src/**/*.mm", recursive=True)
if env["platform"] == "linux":
    sources = [
        s for s in sources
        if not s.replace("\\", "/").startswith("src/ui/linux_cef_bridge/")
    ]

build_sources = [s.replace("src", build_dir, 1) for s in sources]

# Output binary to the installable Godot addon payload.
out_dir = "../godot/addons/fennara/bin"

if env["platform"] == "macos":
    file_name = "libfennara.{}.{}".format(env["platform"], env["target"])
    library = env.SharedLibrary(
        "{}/{}.framework/{}".format(out_dir, file_name, file_name),
        source=build_sources,
    )
else:
    library = env.SharedLibrary(
        "{}/libfennara{}{}".format(out_dir, env["suffix"], env["SHLIBSUFFIX"]),
        source=build_sources,
    )

targets = [library]

if env["platform"] == "linux":
    cef_root = os.environ.get("FENNARA_CEF_ROOT", "")
    cef_wrapper_dir = os.path.join(cef_root, "libcef_dll")
    if not cef_root or not os.path.isdir(cef_wrapper_dir):
        print(
            "Linux CEF bridge build requires FENNARA_CEF_ROOT pointing at the "
            "pinned official CEF 139 binary tree with libcef_dll/."
        )
        Exit(1)

    bridge_env = env.Clone()
    bridge_env.Append(CPPPATH=[cef_root])
    bridge_env.Append(CPPDEFINES=[
        "WRAPPING_CEF_SHARED",
        "__STDC_CONSTANT_MACROS",
        "__STDC_FORMAT_MACROS",
    ])
    bridge_env.Append(CXXFLAGS=[
        "-fPIC",
        "-fvisibility=hidden",
        "-fvisibility-inlines-hidden",
        "-Wno-deprecated-declarations",
        "-Wno-attributes",
        "-Wno-missing-field-initializers",
        "-Wno-unused-parameter",
    ])

    bridge_sources = glob.glob("src/ui/linux_cef_bridge/**/*.cpp", recursive=True)
    bridge_sources += glob.glob(os.path.join(cef_wrapper_dir, "**/*.cc"), recursive=True)
    bridge_library = bridge_env.SharedLibrary(
        "{}/libfennara_linux_cef_bridge".format(out_dir),
        source=bridge_sources,
    )
    targets.append(bridge_library)

Default(targets)
